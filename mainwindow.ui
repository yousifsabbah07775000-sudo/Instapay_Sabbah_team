QLineEdit {
    border: 2px solid #ced4da;
    border-radius: 8px;
    padding: 10px;
    background-color: white;
    min-width: 250px; 
    min-height: 40px;
    font-size: 15px;
    color: #333;
}

QLineEdit:focus {
    border: 2px solid #1a73e8; 
}


QPushButton {
    background-color: #1a73e8;
    color: white;
    border-radius: 10px;
    font-weight: bold;
    font-size: 16px;
    min-width: 150px;
    min-height: 45px;
    margin-top: 10px;
}

